# ── Required ───────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
API_ID=your_api_id
API_HASH=your_api_hash
DATABASE_URI=mongodb+srv://user:pass@cluster.mongodb.net/
LOG_CHANNEL=-1001234567890
FILE_CHANNEL=-1001234567890
ADMINS=123456789 987654321

# ── Optional ───────────────────────────────────────────────────
AUTH_CHANNEL=           # Leave empty to disable force subscribe
DATABASE_NAME=filterbot
MAX_RESULTS=10          # Files shown per search page
MAX_BTN_ROW=2           # File buttons per row
PORT=8000               # Web server port (keep 8000 for Choreo)
